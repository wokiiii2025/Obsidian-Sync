DB_PASSWORD=change-this-db-password
JWT_SECRET=change-this-jwt-secret
HERMES_API_KEY=change-this-hermes-api-key

# Server-side Hermes Agent. Enabling this gives the server-side agent vault encryption access.
HERMES_AGENT_ENABLED=false
HERMES_AGENT_VAULT_ID=
HERMES_AGENT_VAULT_PASSWORD=
HERMES_AGENT_INTERVAL_SECONDS=60
HERMES_AGENT_CREATE_FOLDER=Inbox/Hermes
HERMES_AGENT_GITHUB_PROJECT_FOLDER=30-开发项目/Git开源项目
HERMES_AGENT_INBOX_PATH=Inbox/Telegram.md
HERMES_AGENT_APPEND_SCORE_THRESHOLD=6
HERMES_AGENT_EXCLUSIONS=90-密钥凭证/**
HERMES_AGENT_ROUTING_RULES=

# Admin web panel and database backups
ADMIN_TOKEN=change-this-admin-token
ADMIN_BACKUP_ENABLED=false
ADMIN_BACKUP_INTERVAL_HOURS=24
ADMIN_BACKUP_DIRECTORY=/app/backups
ADMIN_BACKUP_KEEP_LOCAL=14
# Optional rclone target, for example: gdrive:obsidian-sync-backups
ADMIN_BACKUP_RCLONE_REMOTE=
# Optional explicit rclone config path. Leave empty to use /root/.config/rclone/rclone.conf.
ADMIN_BACKUP_RCLONE_CONFIG=
ADMIN_BACKUP_TIMEOUT_SECONDS=600

# Telegram intake service
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=change-this-random-webhook-secret
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_REPLY_ON_QUEUE=true
TELEGRAM_DELETE_AFTER_QUEUE=false
TELEGRAM_POLLING_ENABLED=true
TELEGRAM_POLLING_INTERVAL_SECONDS=2
TELEGRAM_SKIP_PENDING_ON_START=true
TELEGRAM_VAULT_ID=
TELEGRAM_TARGET_NOTE_PATH=Inbox/Telegram.md
